# claudemirror — local config
# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit it.
#
# The bootstrap script will create this file interactively on first run.

# --- Folders to sync ---
# Where Claude Code stores its state. Almost always ~/.claude.
CLAUDE_DIR="$HOME/.claude"

# Optional: an additional folder to sync (e.g. a code directory).
# Leave empty to skip.
EXTRA_SYNC_DIR=""
EXTRA_SYNC_LABEL="code"   # short label used as Syncthing folder ID

# --- Peers ---
# Comma-separated lists, same length. Index N in each refers to the same peer.
# Get a peer's device ID from its Syncthing GUI (Actions -> Show ID), or from the
# end of running bootstrap on that peer.
#
# At least ONE peer must be always-on (PEERS_ALWAYS_ON has a true value for it).

PEER_IDS=""        # e.g. "RMFE4WR-...,VPTJ7HU-..."
PEER_NAMES=""      # e.g. "Desktop,Pi"
PEERS_ALWAYS_ON="" # e.g. "false,true"  -> Pi is the always-on relay
